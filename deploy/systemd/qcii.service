[Unit]
Description=QCII Two-Tone Detector
After=sound.target network.target
Wants=sound.target

[Service]
Type=simple
User=pi
Group=pi
SupplementaryGroups=audio gpio
Environment=PYTHONUNBUFFERED=1
WorkingDirectory=/opt/tonepi
ExecStart=/opt/tonepi/.venv/bin/qcii run --config /opt/tonepi/config/qcii.yaml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
