[Unit]
Description=QCII Two-Tone Detector
After=sound.target network.target
Wants=sound.target

[Service]
Type=simple
User=pi
Group=pi
Environment=PYTHONUNBUFFERED=1
WorkingDirectory=/opt/qcii
ExecStart=/opt/qcii-env/bin/qcii run --config /etc/qcii.yaml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
