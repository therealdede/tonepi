[Unit]
Description=QCII Two-Tone Detector
After=sound.target network.target
Wants=sound.target

[Service]
Type=simple
User=pi
Group=pi
SupplementaryGroups=audio gpio
Environment=PYTHONUNBUFFERED=1
Environment=GPIOZERO_PIN_FACTORY=lgpio
WorkingDirectory=/opt/tonepi
ExecStart=/opt/tonepi/scripts/run-qcii-service.sh /opt/tonepi/config/qcii.yaml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
